# Use mock para desenvolvimento sem custo ou gemini para geracao real.
AI_PROVIDER=mock
GEMINI_MODEL=gemini-2.5-flash
GEMINI_RESEARCH_MODEL=gemini-2.5-flash
ENABLE_FACT_RESEARCH=false

# Segredo do provider, exclusivo do servidor.
GEMINI_API_KEY=

# Chaves publicas usadas pelo cliente sob RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Segredo exclusivo do servidor. Nunca use NEXT_PUBLIC_ neste valor.
SUPABASE_SERVICE_ROLE_KEY=

# Habilite apenas para testes contra um Supabase de desenvolvimento.
RUN_SUPABASE_INTEGRATION=false
APP_URL=http://localhost:3000
